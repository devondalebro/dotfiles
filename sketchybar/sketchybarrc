#!/bin/bash

# 1. Load your separate files
source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"

# 2. Bar Settings
sketchybar --bar \
  height=32 \
  position=top \
  color=$BAR_COLOR \
  border_width=0 \      # <--- Change this to 0
  blur_radius=20 \
  margin=0 \
  y_offset=0 \
  padding_left=10 \
  padding_right=10

# 3. Default Item Settings
sketchybar --default \
  icon.font="Hack Nerd Font:Regular:16.0" \
  icon.color=$ICON_COLOR \
  label.font="Hack Nerd Font:Bold:14.0" \
  label.color=$LABEL_COLOR \
  background.corner_radius=5 \
  background.height=26 \
  padding_left=5 \
  padding_right=5

# 4. Events
sketchybar --add event aerospace_workspace_change
sketchybar --add event volume_change "com.apple.screenIsLocked" "com.apple.sessionDidBecomeActive"

# --- LEFT SIDE ---

# Item: Apple Logo
sketchybar --add item apple left \
           --set apple icon=$ICON_APPLE icon.color=$WHITE

# Item: Spaces (1-9)
for sid in {1..9}; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
    background.color=0x44ffffff \
    background.corner_radius=5 \
    background.height=20 \
    background.drawing=off \
    label="$sid" \
    label.padding_left=10 \
    label.padding_right=10 \
    click_script="aerospace workspace $sid" \
    script="$PLUGIN_DIR/aerospace.sh $sid"
done

# --- CENTER ---

# Item: Front App
sketchybar --add item front_app center \
           --subscribe front_app front_app_switched \
           --set front_app \
           icon.drawing=off \
           label.font="Hack Nerd Font:Bold:15.0" \
           script="$PLUGIN_DIR/front_app.sh"

# --- RIGHT SIDE ---

# Item: CPU
sketchybar --add item cpu right \
           --set cpu \
           update_freq=3 \
           icon=$ICON_CPU \
           icon.color=$RED \
           script="$PLUGIN_DIR/cpu.sh"

# Item: Volume
sketchybar --add item volume right \
           --subscribe volume volume_change \
           --set volume \
           script="$PLUGIN_DIR/volume.sh" \
           icon.color=$BLUE

# Item: Battery
sketchybar --add item battery right \
           --set battery \
           update_freq=120 \
           script="$PLUGIN_DIR/battery.sh" \
           icon.color=$GREEN

# Item: Clock
sketchybar --add item clock right \
           --set clock \
           update_freq=10 \
           icon=$ICON_CLOCK \
           icon.color=$MAGENTA \
           script="$PLUGIN_DIR/clock.sh"

# --- FINALIZE ---
sketchybar --update
echo "SketchyBar config loaded!"
